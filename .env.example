# 部署模式: local 或 cloud
DEPLOYMENT_MODE=local

# 认证开关
ENABLE_AUTH=false

# JWT 密钥（启用认证时必填，至少32字节随机字符串）
JWT_SECRET=replace-with-32-byte-random-secret

# Fernet 加密密钥（用于加密用户 API 密钥）
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-compatible-key

# 跨域来源（本地开发）
CORS_ORIGINS=http://localhost:3000

# SQLite 数据库路径
DATABASE_PATH=data/sessions.db

# LLM 默认配置
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_MODE=hybrid
LLM_FALLBACK_PROVIDERS=deepseek,qwen,gemini

LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2

# LLM API 密钥（至少填一个）
OPENAI_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
THIRD_PARTY_API_KEY=
THIRD_PARTY_BASE_URL=
CLAUDE_API_KEY=
GEMINI_API_KEY=
